# Authentik configuration
# Copy to .env and fill in the values

# Generate with: openssl rand -base64 36
AUTHENTIK_SECRET_KEY=change-me

# PostgreSQL password - generate with: openssl rand -hex 16
PG_PASS=change-me

# Authentik domain
AUTHENTIK_HOST=auth.x86.it

# Let's Encrypt contact email
LETSENCRYPT_EMAIL=your-email@example.com

# From address for Authentik emails
EMAIL_FROM=gass@x86.it

# AWS SES SMTP credentials (eu-west-1)
# Username = AWS Access Key ID
# Password = derived SMTP password (see AWS SES docs)
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=
